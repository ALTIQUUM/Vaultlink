ENVIRONMENT=development
PROJECT_NAME=VAULTLINK
API_V1_PREFIX=/api
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

DATABASE_URL=postgresql+psycopg://vaultlink:vaultlink_dev_password@localhost:5432/vaultlink
POSTGRES_DB=vaultlink
POSTGRES_USER=vaultlink
POSTGRES_PASSWORD=vaultlink_dev_password
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=replace-with-32-byte-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@altiquum.local

ALPHA_VANTAGE_API_KEY=
NEWS_API_KEY=
SENTRY_DSN=
RATE_LIMIT_PER_MINUTE=60
